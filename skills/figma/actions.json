  "create-button-component": {
    "description": "Create a reusable button component with label and background color",
    "params": ["label", "bgColor"],
    "steps": [
      {"action": "press", "key": "f"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "properties.widthInput", "value": "160"},
      {"action": "press", "key": "Tab"},
      {"action": "fill", "selector": "properties.heightInput", "value": "48"},
      {"action": "press", "key": "Enter"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "properties.cornerRadiusInput", "value": "8"},
      {"action": "press", "key": "Enter"},
      {"action": "wait", "ms": 200},
      {"action": "click", "selector": "fill.colorSwatch"},
      {"action": "wait", "ms": 300},
      {"action": "fill", "selector": "colorPicker.hexInput", "value": "{{bgColor}}"},
      {"action": "press", "key": "Enter"},
      {"action": "wait", "ms": 200},
      {"action": "press", "key": "Escape"},
      {"action": "wait", "ms": 200},
      {"action": "press", "key": "Shift+a"},
      {"action": "wait", "ms": 200},
      {"action": "press", "key": "t"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "canvas.activeTextInput", "value": "{{label}}"},
      {"action": "press", "key": "Escape"},
      {"action": "wait", "ms": 200},
      {"action": "press", "key": "Meta+Alt+k"}
    ]
  },
