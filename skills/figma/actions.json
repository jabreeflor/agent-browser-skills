  "create-rectangle": {
    "description": "Create a rectangle with specified dimensions",
    "params": ["width", "height"],
    "steps": [
      {"action": "press", "key": "r"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "properties.widthInput", "value": "{{width}}"},
      {"action": "press", "key": "Tab"},
      {"action": "fill", "selector": "properties.heightInput", "value": "{{height}}"},
      {"action": "press", "key": "Enter"}
    ]
  },
  "create-ellipse": {
    "description": "Create an ellipse with specified dimensions",
    "params": ["width", "height"],
    "steps": [
      {"action": "press", "key": "o"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "properties.widthInput", "value": "{{width}}"},
      {"action": "press", "key": "Tab"},
      {"action": "fill", "selector": "properties.heightInput", "value": "{{height}}"},
      {"action": "press", "key": "Enter"}
    ]
  },
  "create-frame": {
    "description": "Create a frame with specified dimensions",
    "params": ["width", "height"],
    "steps": [
      {"action": "press", "key": "f"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "properties.widthInput", "value": "{{width}}"},
      {"action": "press", "key": "Tab"},
      {"action": "fill", "selector": "properties.heightInput", "value": "{{height}}"},
      {"action": "press", "key": "Enter"}
    ]
  },
  "create-text": {
    "description": "Create a text layer with content",
    "params": ["content"],
    "steps": [
      {"action": "press", "key": "t"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "canvas.activeTextInput", "value": "{{content}}"},
      {"action": "press", "key": "Escape"}
    ]
  },
  "create-line": {
    "description": "Create a line on the canvas",
    "steps": [
      {"action": "press", "key": "l"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200}
