    "steps": [
      {"action": "get", "type": "text", "selector": "properties.xInput", "as": "x"},
      {"action": "get", "type": "text", "selector": "properties.yInput", "as": "y"}
    ]
  },
  "get-layer-name": {
    "description": "Get the name of the currently selected layer",
