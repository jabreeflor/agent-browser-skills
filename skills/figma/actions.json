  },
  "select-frame-tool": {
    "description": "Select the Frame tool",
    "steps": [
      {"action": "press", "key": "f"}
    ]
  },
  "select-rectangle-tool": {
    "description": "Select the Rectangle tool",
    "steps": [
      {"action": "press", "key": "r"}
    ]
  },
  "select-ellipse-tool": {
    "description": "Select the Ellipse tool",
    "steps": [
      {"action": "press", "key": "o"}
    ]
  },
  "select-line-tool": {
    "description": "Select the Line tool",
    "steps": [
      {"action": "press", "key": "l"}
    ]
  },
  "select-pen-tool": {
    "description": "Select the Pen tool",
    "steps": [
      {"action": "press", "key": "p"}
    ]
  },
  "select-text-tool": {
    "description": "Select the Text tool",
