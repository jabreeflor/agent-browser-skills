      {"action": "press", "key": "Enter"},
      {"action": "wait", "ms": 200},
      {"action": "click", "selector": "stroke.addButton"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "properties.cornerRadiusInput", "value": "6"},
      {"action": "press", "key": "Enter"},
      {"action": "wait", "ms": 200},
      {"action": "press", "key": "Shift+a"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "autoLayout.paddingInput", "value": "12"},
      {"action": "press", "key": "Enter"},
      {"action": "wait", "ms": 200},
      {"action": "press", "key": "t"},
      {"action": "click", "selector": "canvas.center"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "canvas.activeTextInput", "value": "{{placeholder}}"},
      {"action": "press", "key": "Escape"},
      {"action": "wait", "ms": 200},
      {"action": "fill", "selector": "properties.opacityInput", "value": "50"},
      {"action": "press", "key": "Enter"}
    ]
  },
  "get-selection-size": {
    "description": "Get the width and height of the current selection",
    "returns": ["width", "height"],
    "steps": [
      {"action": "get", "type": "text", "selector": "properties.widthInput", "as": "width"},
      {"action": "get", "type": "text", "selector": "properties.heightInput", "as": "height"}
    ]
  },
  "get-selection-position": {
    "description": "Get the X and Y position of the current selection",
